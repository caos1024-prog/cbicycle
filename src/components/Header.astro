---
import { SITE_TITLE } from '../consts';

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header>
	<nav>
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="links">
			<a href="/blog" class:list={{ active: isActive('/blog') }}>Blog 博客</a>
			<a href="/about" class:list={{ active: isActive('/about') }}>About 关于</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid var(--line);
		background: rgba(16, 20, 17, 0.72);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
	}
	nav {
		width: min(var(--wide-width), calc(100% - 40px));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 15px 0;
	}
	.brand {
		font-weight: 700;
		font-size: 1.05rem;
		color: var(--ink);
		text-decoration: none;
	}
	.links {
		display: flex;
		gap: 22px;
		font-size: 0.92rem;
	}
	.links a {
		color: var(--muted);
		text-decoration: none;
	}
	.links a:hover,
	.links a.active {
		color: var(--ink);
	}
</style>
