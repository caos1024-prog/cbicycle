---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<section class="hero">
			<header class="hero-nav">
				<div class="hero-nav-inner">
					<span class="brand">cbicycle.com</span>
					<a class="enter" href="/blog">Enter blog 进入博客 →</a>
				</div>
			</header>
			<div class="hero-wrap">
				<div class="hero-copy">
					<h1>CBicycle</h1>
					<p class="lede">
						A quiet place for rides, notes, tools, and the small routes that become habits.
					</p>
					<p class="lede zh">关于骑行、笔记、工具,和那些慢慢变成习惯的小路线。</p>
					<div class="meta-row">
						<span>Personal site · 个人站点</span>
						<span>Tokyo time, slow mornings</span>
						<span>Built on Cloudflare</span>
					</div>
				</div>
			</div>
		</section>

		<main class="latest">
			<div class="latest-head">
				<h2>Latest · 最新</h2>
				<a href="/blog">All posts 全部 →</a>
			</div>
			{
				posts.length === 0 ? (
					<p class="empty">还没有文章 · No posts yet.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="row">
										<span class="lang-badge">{post.data.lang === 'zh' ? '中' : 'EN'}</span>
										<FormattedDate date={post.data.pubDate} />
									</span>
									<span class="title">{post.data.title}</span>
									{post.data.description && <span class="desc">{post.data.description}</span>}
								</a>
							</li>
						))}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		position: relative;
		min-height: 86svh;
		display: flex;
		align-items: center;
		isolation: isolate;
		overflow: hidden;
	}
	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -2;
		background:
			linear-gradient(
				90deg,
				rgba(9, 12, 10, 0.94) 0%,
				rgba(9, 12, 10, 0.78) 34%,
				rgba(9, 12, 10, 0.3) 64%,
				rgba(9, 12, 10, 0.2) 100%
			),
			url('/hero-bike.jpg') center / cover no-repeat;
		transform: scale(1.01);
	}
	.hero::after {
		content: '';
		position: absolute;
		inset: auto 0 0;
		height: 22svh;
		z-index: -1;
		background: linear-gradient(0deg, var(--night), transparent);
	}
	.hero-nav {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		padding: 24px 0;
	}
	.hero-nav-inner,
	.hero-wrap {
		width: min(var(--wide-width), calc(100% - 40px));
		margin: 0 auto;
	}
	.hero-nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		font-size: 0.9rem;
	}
	.hero-nav .brand {
		font-weight: 700;
		color: var(--ink);
	}
	.hero-nav .enter {
		color: var(--muted);
	}
	.hero-nav .enter:hover {
		color: var(--ink);
		text-decoration: none;
	}
	.hero-copy {
		width: min(640px, 100%);
		padding: 96px 0 64px;
	}
	.hero-copy h1 {
		margin: 0;
		font-size: clamp(48px, 8vw, 100px);
		line-height: 0.92;
	}
	.lede {
		margin: 24px 0 0;
		max-width: 540px;
		color: var(--muted);
		font-size: clamp(17px, 2.2vw, 22px);
		line-height: 1.45;
	}
	.lede.zh {
		margin-top: 10px;
		color: var(--faint);
	}
	.meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 10px 20px;
		margin-top: 38px;
		padding-top: 22px;
		border-top: 1px solid var(--line);
		color: var(--faint);
		font-size: 0.85rem;
	}
	.latest {
		width: min(820px, calc(100% - 40px));
		margin: 0 auto;
		padding: 64px 0 0;
	}
	.latest-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 16px;
	}
	.latest-head h2 {
		margin: 0;
	}
	.latest-head a {
		color: var(--muted);
		font-size: 0.9rem;
	}
	.empty {
		color: var(--muted);
		margin-top: 1.5em;
	}

	@media (max-width: 720px) {
		.hero {
			min-height: 84svh;
			align-items: flex-end;
		}
		.hero::before {
			background:
				linear-gradient(
					180deg,
					rgba(9, 12, 10, 0.25) 0%,
					rgba(9, 12, 10, 0.6) 40%,
					rgba(9, 12, 10, 0.95) 100%
				),
				url('/hero-bike.jpg') 62% center / cover no-repeat;
		}
		.hero-copy {
			width: 100%;
			padding: 110px 0 48px;
		}
	}
</style>
