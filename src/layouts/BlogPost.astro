---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, lang } = Astro.props;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh' : 'en'}>
	<head>
		<BaseHead title={title} description={description ?? ''} />
	</head>
	<body>
		<Header />
		<main class="prose-wrap">
			<article>
				<div class="post-head">
					<div class="row">
						<span class="lang-badge">{lang === 'zh' ? '中文' : 'EN'}</span>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									· updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					{description && <p class="desc">{description}</p>}
				</div>
				{heroImage && <Image class="hero-image" width={1020} height={510} src={heroImage} alt="" />}
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-head {
		margin-bottom: 1.6em;
	}
	.post-head .row {
		display: flex;
		align-items: center;
		gap: 12px;
		color: var(--faint);
		font-size: 0.85rem;
		margin-bottom: 0.9em;
	}
	.post-head h1 {
		margin: 0 0 0.3em;
		font-size: clamp(28px, 5vw, 44px);
	}
	.post-head .desc {
		color: var(--muted);
		font-size: 1.1rem;
		margin: 0;
	}
	.hero-image {
		width: 100%;
		margin: 0 0 1.5em;
	}
	.prose :global(h2) {
		margin-top: 1.6em;
	}
	.prose :global(h3) {
		margin-top: 1.4em;
	}
	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.3em;
	}
	.prose :global(li) {
		margin-bottom: 0.4em;
	}
	.prose :global(img) {
		margin: 1.5em 0;
	}
</style>
